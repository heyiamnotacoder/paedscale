ANTHROPIC_API_KEY=your-anthropic-api-key-here
ALLOWED_ORIGINS=http://localhost:3000

# Optional: raises the PubMed E-utilities rate limit (research tools work without it).
NCBI_API_KEY=

# Multi-agent cost/latency controls.
# Hard ceiling ~$2 so critic + submit can finish; typical runs should be far lower.
PAEDSCALE_ORCH_MODEL=claude-sonnet-5
PAEDSCALE_SUBAGENT_MODEL=claude-haiku-4-5-20251001
PAEDSCALE_CRITIC_MODEL=claude-sonnet-5
PAEDSCALE_MAX_TURNS=14
PAEDSCALE_RESEARCH_MAX_TURNS=7
PAEDSCALE_SUBAGENT_MAX_TURNS=7
PAEDSCALE_BUDGET_USD=2.0
