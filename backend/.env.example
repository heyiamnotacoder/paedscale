ANTHROPIC_API_KEY=your-anthropic-api-key-here
ALLOWED_ORIGINS=http://localhost:3000

# Deterministic drug data (happy path). Optional key raises the openFDA rate limit.
OPENFDA_API_KEY=
# Optional: seed cache path for instant drug hits (defaults to tests/fixtures/validation_drugs.json).
# PAEDSCALE_DRUG_SEED=

# Edge-case literature. Optional NCBI key raises the PubMed rate limit.
NCBI_API_KEY=
# Optional: route edge-case literature through an MCP server instead of pubmed_search.
# JSON array of {"type":"url","name":"...","url":"...","authorization_token":"..."}
PAEDSCALE_MCP_SERVERS=

# Orchestrator (single in-process Messages-API agent loop; Sonnet for everything).
PAEDSCALE_ORCH_MODEL=claude-sonnet-5
PAEDSCALE_MAX_TURNS=8
PAEDSCALE_MAX_TOKENS=8000
# Parallel guideline sub-agent (set to 0 to disable for pure speed).
PAEDSCALE_GUIDELINE_AGENT=1
